# Nuxt Page Config
NUXT_SITE_NAME="Applicationname"
NUXT_SITE_ENV="development"
NUXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database Configuration
NUXT_DATABASE_HOST="localhost"
NUXT_DATABASE_PORT="5432"
NUXT_DATABASE_USER="postgres"
NUXT_DATABASE_PASSWORD="postgres"
NUXT_DATABASE_NAME="nuxt-starter"

# Authentication Configuration
NUXT_AUTH_SECRET=""

# Email Configuration
NUXT_EMAIL_PROVIDER="console"  # 'console' or 'smtp'

# SMTP Settings (only needed when NUXT_EMAIL_PROVIDER="smtp")
# NUXT_SMTP_HOST=""
# NUXT_SMTP_PORT="587"
# NUXT_SMTP_USER=""
# NUXT_SMTP_PASS=""
# NUXT_SMTP_FROM="noreply@example.com"

# Storage Configuration
NUXT_STORAGE_PROVIDER="local"  # 'local' or 's3'
# NUXT_STORAGE_LOCAL_PATH="./storage/uploads"
# NUXT_STORAGE_MAX_FILE_SIZE="5242880"  # 5MB in bytes
# NUXT_STORAGE_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/gif"

# S3 Settings (only needed when NUXT_STORAGE_PROVIDER="s3")
# NUXT_S3_BUCKET=""
# NUXT_S3_REGION=""
# NUXT_S3_ENDPOINT=""
# NUXT_S3_ACCESS_KEY_ID=""
# NUXT_S3_SECRET_ACCESS_KEY=""

# Orchestrator
# AI provider API keys are NOT here — they live encrypted in the DB (see DESIGN-AI / ADR-014).
NUXT_ORCHESTRATOR_HISTORY_LIMIT="30"  # default per-conversation message context limit; can be overridden per workspace

# GitHub Integration (Phase 4)
NUXT_GITHUB_SYNC_INTERVAL_MINUTES="15"
NUXT_GITHUB_COMMITS_PER_SYNC="50"

# i18n
NUXT_PUBLIC_I18N_DEFAULT_LOCALE="de"

# MCPS
MCP_CONTEXT7_API_KEY=""